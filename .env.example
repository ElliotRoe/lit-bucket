# Copy to .env and fill in — `docker compose up` reads it automatically.
# Do NOT commit the real .env (it's git-ignored; only this example is tracked).

# ── Storage backend (required) ───────────────────────────────────────────────
# Where attachments, derived markdown, the LanceDB index, and the manifest live.
# Used by the worker, the MCP server, AND the rclone WebDAV remote.
#   s3://my-literature   -> Cloudflare R2 (fill in the R2_* creds below)
#   /data/lit            -> local filesystem (kept on-disk via the bind mount)
ZDAV_STORE=s3://my-literature

# For the local mode: host directory that backs /data/lit inside the container.
# These become normal, browsable files on the host (attachments/, derived/, …).
LIT_DATA_DIR=/data/lit-data

# ── Cloudflare R2 creds (only needed when ZDAV_STORE is s3://…) ───────────────
# Create an R2 API token (S3 Auth) in the Cloudflare dashboard.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# ── WebDAV auth (required) ───────────────────────────────────────────────────
# Credentials Zotero connects with (Settings → Sync → File Syncing → WebDAV).
WEBDAV_USER=zotero
WEBDAV_PASS=change-me
# WEBDAV_ADDR=:8080          # listen address inside the container (default)

# ── MCP remote search server ─────────────────────────────────────────────────
# Served at http://<host>:<MCP_PORT>/mcp. NOTE: unauthenticated — keep it on a
# trusted network or front it with a tunnel/reverse proxy.
MCP_TRANSPORT=streamable-http   # set 'stdio' for a local (non-remote) client
MCP_HOST=0.0.0.0
MCP_PORT=8000
# Shared API key: if set, every request must send it as
#   Authorization: Bearer <key>   (or)   X-API-Key: <key>
# Leave blank to run the server open (only safe on a trusted network).
MCP_API_KEY=

# ── Optional tuning ──────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5   # sentence-transformers model (index + query)
POLL_INTERVAL=60                     # seconds between R2 polls
DOCLING_TIMEOUT=900                  # seconds before a PDF parse is abandoned
